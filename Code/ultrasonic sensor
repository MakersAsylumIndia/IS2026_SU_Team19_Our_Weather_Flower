#define TRIG 5
#define ECHO 18

void setup() {
  Serial.begin(115200);
  pinMode(TRIG, OUTPUT);
  pinMode(ECHO, INPUT);
}

void loop() {
  // send a quick pulse out
  digitalWrite(TRIG, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG, LOW);

  // listen for the echo coming back (30ms timeout ≈ 5m max)
  long duration = pulseIn(ECHO, HIGH, 30000);

  // convert time into distance (cm)
  float distance = duration * 0.0343 / 2;

  if (duration == 0) {
    Serial.println("Out of range / no echo");
  } else {
    Serial.print("Distance: ");
    Serial.print(distance);
    Serial.println(" cm");
  }

  delay(500);
}
