#include "DHT.h"

#define DHTPIN 4        // the GPIO you wired DATA to
#define DHTTYPE DHT22   // tell it we're using a DHT22

DHT dht(DHTPIN, DHTTYPE);

void setup() {
  Serial.begin(115200);
  dht.begin();
}

void loop() {
  delay(2000);  // DHT22 is slow, needs ~2s between reads

  float humidity = dht.readHumidity();
  float tempC = dht.readTemperature();

  // if either read fails, you get "nan"
  if (isnan(humidity) || isnan(tempC)) {
    Serial.println("Failed to read — check wiring!");
    return;
  }

  Serial.print("Temp: ");
  Serial.print(tempC);
  Serial.print(" °C   Humidity: ");
  Serial.print(humidity);
  Serial.println(" %");
}
